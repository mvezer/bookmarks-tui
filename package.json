{
  "name": "bookmarks-tui",
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.61.1"
  },
  "private": true,
  "type": "module",
  "bin": {
    "bookmarks-tui": "./tui-app/src/index.ts"
  },
  "scripts": {
    "start": "bun run tui-app/src/index.ts",
    "dev": "bun run --watch tui-app/src/index.ts",
    "build:connector-chrome": "rm -rf tui-connector-chrome/dist && bun run build.ts connector-chrome",
    "build:app": "bun run build.ts app"
  },
  "workspaces": [
    "common",
    "tui-app",
    "tui-connector-chrome"
  ],
  "dependencies": {
    "env-paths": "^4.0.0"
  }
}
